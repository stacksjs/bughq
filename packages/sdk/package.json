{
  "name": "@bughq/sdk",
  "type": "module",
  "version": "0.1.0",
  "description": "bughq error tracking — framework-agnostic browser SDK",
  "license": "MIT",
  "homepage": "https://bughq.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/bughq.git",
    "directory": "packages/sdk"
  },
  "keywords": ["bughq", "error-tracking", "sdk", "monitoring"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --minify",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
