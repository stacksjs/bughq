{
  "name": "@bughq/stx",
  "type": "module",
  "version": "0.1.0",
  "description": "bughq error tracking — Stacks / stx apps (client + server)",
  "license": "MIT",
  "homepage": "https://bughq.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/bughq.git",
    "directory": "packages/stx"
  },
  "keywords": ["bughq", "error-tracking", "stacks", "stx", "bun"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./BugHQ.stx": "./resources/BugHQ.stx"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "resources", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean --external @bughq/sdk",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bughq/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
