{
  "name": "@bughq/vue",
  "type": "module",
  "version": "0.1.0",
  "description": "bughq error tracking — Vue 3 plugin",
  "license": "MIT",
  "homepage": "https://bughq.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/bughq.git",
    "directory": "packages/vue"
  },
  "keywords": ["bughq", "error-tracking", "vue", "vue3", "plugin"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external vue",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bughq/sdk": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.5.13"
  }
}
